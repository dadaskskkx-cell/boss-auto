llm:
  base_url: "https://open.bigmodel.cn/api/anthropic"
  api_key: "sk-xxx"  # 替换为你的 GLM API Key
  model: "glm-5"
  vision_provider: "zhipu_openai"
  vision_base_url: "https://open.bigmodel.cn/api/paas/v4/"
  vision_model: "glm-4.6v-flash"
  vision_api_key: "sk-xxx"  # 可与上面的 api_key 保持一致
  vision_retry_count: 3
  vision_retry_delay_seconds: 2

scheduler:
  resume_scan_interval: 10     # 扫描简历间隔（分钟）

boss:
  base_url: "https://www.zhipin.com"

rpa:
  dry_run: true
  minimum_keywords: 3
  required_keywords:
    - "消息"
    - "推荐"
    - "搜索"
    - "职位"
    - "互动"

workflow:
  screen_scan_limit: 0
  max_empty_screens: 5
  scroll_pages_per_turn: 3
  detail_pause_seconds: 1.2


messaging:
  matched_template: |
    你好！看到你的简历觉得和我们的岗位很匹配，方便回答几个问题吗？
    1. 目前是在职还是离职状态？
    2. 期望薪资范围是多少？
    3. 最快多久可以到岗？
  rejected_template: |
    感谢你的关注，经过评估你的经历与当前岗位需求不太匹配，祝你求职顺利！
  processed_ids_file: "data/processed_ids.json"

logging:
  level: "INFO"
  file: "data/logs/boss_auto.log"
